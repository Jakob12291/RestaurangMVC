@model HomeViewModel
@{
    ViewData["Title"] = "Hem";
    ViewData["Description"] = "Bella Cucina i Stockholm – autentisk italiensk matlagning med färska råvaror, handgjord pasta och ett varmt välkomnande. Se menyn och boka bord online.";
}

@section Scripts {
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "Restaurant",
      "name": "Bella Cucina",
      "servesCuisine": "Italian",
      "priceRange": "$$",
      "telephone": "+46812345678",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "Via Roma 12",
        "postalCode": "111 22",
        "addressLocality": "Stockholm",
        "addressCountry": "SE"
      }
    }
    </script>
}

<section class="bc-hero">
    <div class="container text-center">
        <p class="bc-eyebrow">Benvenuti · Välkommen</p>
        <h1>Smaken av Italien, mitt i Stockholm</h1>
        <p>
            På Bella Cucina lagar vi mat med hjärta – handgjord pasta, vedugnsbakad pizza
            och råvaror direkt från Italien. En bit av la dolce vita, varje dag.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Meny" asp-action="Index" class="btn-bc">Se vår meny</a>
            <a asp-controller="Bokning" asp-action="Index" class="btn-bc-outline">Boka bord</a>
        </div>
    </div>
</section>

<section class="bc-section">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-lg-6">
                <p class="bc-eyebrow">Vår historia</p>
                <h2 class="mb-3">Familjetradition sedan 1998</h2>
                <p class="text-muted">
                    Bella Cucina grundades av familjen Rossi med en enkel idé: att dela den
                    italienska matglädjen med Stockholm. I vårt kök möts generationers recept
                    med årstidens bästa råvaror.
                </p>
                <p class="text-muted">
                    Hos oss ska du känna dig som hemma hos en italiensk farmor – god mat,
                    värme och tid att njuta.
                </p>
                <a asp-controller="Bokning" asp-action="Index" class="btn-bc mt-2">Boka ditt besök</a>
            </div>
            <div class="col-lg-6">
                <img class="img-fluid rounded-4 shadow-sm"
                     src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=900&q=70"
                     width="900" height="600" loading="lazy"
                     alt="Matsalen på den italienska restaurangen Bella Cucina" />
            </div>
        </div>
    </div>
</section>

<section class="bc-section bc-section--alt">
    <div class="container">
        <div class="bc-section-head">
            <p class="bc-eyebrow">Gästernas favoriter</p>
            <h2>Populära rätter</h2>
            <p>Ett urval av det våra gäster älskar allra mest.</p>
        </div>

        @if (Model.PopuläraRätter.Count == 0)
        {
            <p class="text-center text-muted">Menyn är inte tillgänglig just nu. Titta in igen snart!</p>
        }
        else
        {
            <div class="row g-4">
                @foreach (var rätt in Model.PopuläraRätter)
                {
                    <div class="col-md-4">
                        <article class="bc-card">
                            @if (!string.IsNullOrWhiteSpace(rätt.BildUrl))
                            {
                                <img class="bc-card__img" src="@rätt.BildUrl" loading="lazy"
                                     width="400" height="300" alt="@rätt.Namn" />
                            }
                            else
                            {
                                <div class="bc-card__placeholder">🍝</div>
                            }
                            <div class="bc-card__body">
                                @if (rätt.IsPopular) { <span class="bc-badge">Populär</span> }
                                <div class="bc-card__title">
                                    <h3>@rätt.Namn</h3>
                                    <span class="bc-price">@rätt.Pris.ToString("0") kr</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(rätt.Beskrivning))
                                {
                                    <p class="text-muted mt-2 mb-0">@rätt.Beskrivning</p>
                                }
                            </div>
                        </article>
                    </div>
                }
            </div>
        }

        <div class="text-center mt-4">
            <a asp-controller="Meny" asp-action="Index" class="btn-bc">Se hela menyn</a>
        </div>
    </div>
</section>
