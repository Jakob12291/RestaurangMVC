@model List<MenyItem>
@{
    ViewData["Title"] = "Meny";
}

<div class="bc-admin-head">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h1>Meny</h1>
        <a asp-action="Create" class="btn-bc">+ Ny rätt</a>
    </div>
</div>

<div class="container pb-5">
    @if (Model.Count == 0)
    {
        <p class="text-muted">Inga rätter ännu.</p>
    }
    else
    {
        <div class="table-responsive bc-card">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Bild</th><th>Namn</th><th>Pris</th><th>Populär</th><th class="text-end">Åtgärder</th></tr>
                </thead>
                <tbody>
                @foreach (var m in Model.OrderBy(x => x.Namn))
                {
                    <tr>
                        <td style="width:80px;">
                            @if (!string.IsNullOrWhiteSpace(m.BildUrl))
                            {
                                <img src="@m.BildUrl" alt="@m.Namn" width="64" height="48"
                                     loading="lazy" style="object-fit:cover;border-radius:8px;" />
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            <strong>@m.Namn</strong>
                            @if (!string.IsNullOrWhiteSpace(m.Beskrivning))
                            {
                                <div class="text-muted small">@m.Beskrivning</div>
                            }
                        </td>
                        <td>@m.Pris.ToString("0") kr</td>
                        <td>@(m.IsPopular ? "Ja" : "Nej")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">Ändra</a>
                            <a asp-action="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
