@model MenyItem
@{
    ViewData["Title"] = "Ta bort rätt";
}

<div class="bc-admin-head"><div class="container"><h1>Ta bort rätt</h1></div></div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="bc-card p-4">
                <p>Är du säker på att du vill ta bort <strong>@Model.Namn</strong> (@Model.Pris.ToString("0") kr)?</p>
                <form method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Ja, ta bort</button>
                    <a asp-action="Index" class="btn btn-link">Avbryt</a>
                </form>
            </div>
        </div>
    </div>
</div>
