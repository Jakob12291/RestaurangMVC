@model Bokning
@{
    ViewData["Title"] = "Ta bort bokning";
}

<div class="bc-admin-head"><div class="container"><h1>Ta bort bokning</h1></div></div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="bc-card p-4">
                <p>Vill du ta bort bokningen för <strong>@Model.KundNamn</strong>?</p>
                <ul class="text-muted">
                    <li>Bord @Model.Bordsnummer</li>
                    <li>@Model.StartTid.ToString("yyyy-MM-dd HH:mm") – @Model.SlutTid.ToString("HH:mm")</li>
                    <li>@Model.AntalGaster gäster</li>
                </ul>
                <form method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Ja, ta bort</button>
                    <a asp-action="Index" class="btn btn-link">Avbryt</a>
                </form>
            </div>
        </div>
    </div>
</div>
