@model List<Bord>
@{
    ViewData["Title"] = "Bord";
}

<div class="bc-admin-head">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h1>Bord</h1>
        <a asp-action="Create" class="btn-bc">+ Nytt bord</a>
    </div>
</div>

<div class="container pb-5">
    @if (Model.Count == 0)
    {
        <p class="text-muted">Inga bord ännu.</p>
    }
    else
    {
        <div class="table-responsive bc-card">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Bordsnummer</th><th>Kapacitet</th><th class="text-end">Åtgärder</th></tr>
                </thead>
                <tbody>
                @foreach (var b in Model.OrderBy(x => x.Bordsnummer))
                {
                    <tr>
                        <td>Bord @b.Bordsnummer</td>
                        <td>@b.Kapacitet platser</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">Ändra</a>
                            <a asp-action="Delete" asp-route-id="@b.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
