@model List<Bokning>
@{
    ViewData["Title"] = "Bokningar";
}

<div class="bc-admin-head">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h1>Bokningar</h1>
        <a asp-action="Create" class="btn-bc">+ Ny bokning</a>
    </div>
</div>

<div class="container pb-5">
    @if (Model.Count == 0)
    {
        <p class="text-muted">Inga bokningar ännu.</p>
    }
    else
    {
        <div class="table-responsive bc-card">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Datum &amp; tid</th><th>Slutar</th><th>Bord</th><th>Gäst</th><th>Antal</th><th class="text-end">Åtgärder</th></tr>
                </thead>
                <tbody>
                @foreach (var b in Model.OrderBy(x => x.StartTid))
                {
                    <tr>
                        <td>@b.StartTid.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@b.SlutTid.ToString("HH:mm")</td>
                        <td>Bord @b.Bordsnummer</td>
                        <td>@b.KundNamn</td>
                        <td>@b.AntalGaster st</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">Ändra</a>
                            <a asp-action="Delete" asp-route-id="@b.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
