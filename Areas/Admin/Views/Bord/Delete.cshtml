@model Bord
@{
    ViewData["Title"] = "Ta bort bord";
}

<div class="bc-admin-head"><div class="container"><h1>Ta bort bord</h1></div></div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="bc-card p-4">
                <p>Är du säker på att du vill ta bort <strong>Bord @Model.Bordsnummer</strong> (@Model.Kapacitet platser)?</p>
                <p class="text-danger small">Eventuella bokningar kopplade till bordet tas också bort.</p>
                <form method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Ja, ta bort</button>
                    <a asp-action="Index" class="btn btn-link">Avbryt</a>
                </form>
            </div>
        </div>
    </div>
</div>
