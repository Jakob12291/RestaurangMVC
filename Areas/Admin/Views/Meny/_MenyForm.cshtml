@model MenyFormModel

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="Namn" class="form-label"></label>
    <input asp-for="Namn" class="form-control" />
    <span asp-validation-for="Namn" class="text-danger small"></span>
</div>
<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Pris" class="form-label"></label>
        <input asp-for="Pris" class="form-control" />
        <span asp-validation-for="Pris" class="text-danger small"></span>
    </div>
    <div class="col-md-6 mb-3 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="IsPopular" class="form-check-input" />
            <label asp-for="IsPopular" class="form-check-label"></label>
        </div>
    </div>
</div>
<div class="mb-3">
    <label asp-for="Beskrivning" class="form-label"></label>
    <textarea asp-for="Beskrivning" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Beskrivning" class="text-danger small"></span>
</div>
<div class="mb-4">
    <label asp-for="BildUrl" class="form-label"></label>
    <input asp-for="BildUrl" class="form-control" placeholder="https://..." />
    <span asp-validation-for="BildUrl" class="text-danger small"></span>
</div>
